GATEWAY_APP_NAME=anotherme2-gateway
GATEWAY_ENV=dev
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080

# Postgres for production, sqlite for local quick start
GATEWAY_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/anotherme2

GATEWAY_REDIS_URL=redis://localhost:6379/0
GATEWAY_QUEUE_COURSE=q.course
GATEWAY_QUEUE_PROBLEM_VIDEO=q.problem_video
GATEWAY_QUEUE_PACKAGE=q.package
GATEWAY_DLQ_PREFIX=q.dlq
GATEWAY_MAX_RETRIES=2
GATEWAY_RETRY_BASE_SECONDS=5

OPENMAIC_BASE_URL=http://localhost:3000
OPENMAIC_POLL_SECONDS=5
OPENMAIC_TIMEOUT_SECONDS=1200

# local | s3 | minio
OBJECT_STORAGE_DRIVER=local
OBJECT_STORAGE_BUCKET=anotherme2-artifacts
OBJECT_STORAGE_ENDPOINT_URL=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_PUBLIC_BASE_URL=
LOCAL_STORAGE_ROOT=./gateway_data/objects
GATEWAY_WORKER_TEMP_ROOT=./gateway_data/tmp

# optional phase-1 auth token
GATEWAY_API_TOKEN=
